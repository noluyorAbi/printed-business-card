# Template for .editorconfig at the repository root.
# Copy to ".editorconfig" (with the leading dot). No tokens to replace.
#
# EditorConfig is supported natively by most editors and through a plugin in
# the rest. It settles indentation and whitespace before review has to.
# Reference: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Python has its own settled convention, and fighting it is not worth it.
[*.py]
indent_size = 4
max_line_length = 88

# Makefiles are one of the few formats where a tab is load bearing.
[Makefile]
indent_style = tab

[*.{mk,mak}]
indent_style = tab

# Go is formatted by gofmt, which uses tabs and does not ask.
[*.go]
indent_style = tab

# Markdown uses two trailing spaces as a hard line break, so trimming them
# silently changes the rendered output.
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# YAML breaks on tabs. Being explicit costs one line.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}]
indent_size = 2

[*.{css,scss,html}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

# Windows batch files want CRLF, matching the .gitattributes rule.
[*.{bat,cmd}]
end_of_line = crlf
