# Two jobs here.
#
# 1. LINE ENDINGS. "text=auto eol=lf" normalises to LF in the repository and
#    checks out LF everywhere, including Windows. Without it, a Windows clone
#    rewrites text files to CRLF and diffs get noisy.
#
# 2. LANGUAGE STATS. GitHub guesses the repository's primary language by
#    counting bytes, and the committed preview/icons could outweigh the actual
#    source. "linguist-generated" keeps them out of the language bar.

# ---------------------------------------------------------------- defaults
* text=auto eol=lf

# --------------------------------------------------------------- binaries
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.zip   binary
*.pdf   binary
*.stl   binary
*.3mf   binary

# SVG is text, so it stays diffable, but a diff of a path with two thousand
# points helps nobody.
*.svg   text eol=lf -diff

# ----------------------------------------------------------- generated assets
# Rendered by build_card.py, committed on purpose because the README
# references them.
assets/**            linguist-generated=true

# ------------------------------------------------------------- documentation
*.md                 text eol=lf

# ---------------------------------------------------------- export excludes
# Files that do not belong in the tarball GitHub builds for a release.
.github/             export-ignore
.gitattributes       export-ignore
.gitignore           export-ignore
tests/               export-ignore

# ------------------------------------------------------------------ scripts
*.sh                 text eol=lf
